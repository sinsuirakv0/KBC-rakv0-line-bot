# qr, password, or token
LINE_LOGIN_METHOD=qr

# Used when LINE_LOGIN_METHOD=password
LINE_EMAIL=
LINE_PASSWORD=
LINE_LOGIN_PIN=114514

# Optional. If set, token login is used before QR/password.
LINE_AUTH_TOKEN=

# Common devices: IOSIPAD, DESKTOPWIN, ANDROIDSECONDARY
LINE_DEVICE=IOSIPAD
LINE_STORAGE_FILE=./storage/storage.json

# Set true when you need to skip the saved auth token and run QR/password login again.
LINE_FORCE_LOGIN=false

# Used by password login. QR login can also save E2EE keys when LINE returns them.
LINE_E2EE_LOGIN=true

# Bot behavior
COMMAND_PREFIX=!
ENABLE_TALK=true
ENABLE_SQUARE=true

# GitHub Actions event-update receiver
PORT=3000
EVENT_UPDATE_SECRET=

# !push skd subscriptions. Local JSON is enough for development.
PUSH_SUBSCRIPTIONS_FILE=./storage/push-subscriptions.json

# Optional GitHub-backed persistence for container redeploys.
# A separate private repository is recommended so runtime data does not redeploy this bot.
PUSH_SUBSCRIPTIONS_GITHUB_REPO=
PUSH_SUBSCRIPTIONS_GITHUB_PATH=subscriptions/push-subscriptions.json
PUSH_SUBSCRIPTIONS_GITHUB_BRANCH=main
PUSH_SUBSCRIPTIONS_GITHUB_TOKEN=

# Encrypted LINE token, certificate, and E2EE key backup in the same data repository.
LINE_STORAGE_GITHUB_PATH=line-auth/storage.enc.json
LINE_STORAGE_BACKUP_KEY=
LINE_STORAGE_BACKUP_INTERVAL_MS=30000

# Automatic session recovery
LINE_LOGIN_RETRY_MS=15000
LINE_AUTH_WATCHDOG_MS=60000
LINE_TALK_POLL_TIMEOUT_MS=5000
LINE_TALK_POLL_INTERVAL_MS=250

# Event-start push subscriptions and JST scheduler
EVENT_PUSH_SUBSCRIPTIONS_FILE=./storage/event-push-subscriptions.json
EVENT_PUSH_STATE_FILE=./storage/event-push-state.json
EVENT_PUSH_SUBSCRIPTIONS_GITHUB_PATH=subscriptions/event-start.json
EVENT_PUSH_STATE_GITHUB_PATH=state/event-start-notifications.json
EVENT_PUSH_INTERVAL_MS=15000
EVENT_PUSH_LOOKBACK_MS=600000

# !push one-shot reminders. GitHub persistence uses the repository and token above.
PUSH_REMINDERS_FILE=./storage/push-reminders.json
PUSH_REMINDERS_GITHUB_PATH=state/push-reminders.json
PUSH_REMINDER_INTERVAL_MS=10000

# Command ranking. GitHub persistence uses the repository and token above.
RANKING_FILE=./storage/ranking.json
RANKING_GITHUB_PATH=stats/ranking.json

# Bot runtime status. GitHub persistence uses the repository and token above.
BOT_STATUS_FILE=./storage/bot-status.json
BOT_STATUS_GITHUB_PATH=stats/bot-status.json

# Bot admin/moderator permissions and BAN state. GitHub persistence uses the repository and token above.
PERMISSIONS_FILE=./storage/permissions.json
PERMISSIONS_GITHUB_PATH=settings/permissions.json

# OpenChat kick history. GitHub persistence uses the repository and token above.
OC_KICK_HISTORY_FILE=./storage/oc-kick-history.json
OC_KICK_HISTORY_GITHUB_PATH=moderation/oc-kick-history.json

# OpenChat moderation settings. Media burst means N image/video messages inside the window.
OC_MODERATION_SETTINGS_FILE=./storage/oc-moderation-settings.json
OC_MODERATION_SETTINGS_GITHUB_PATH=moderation/oc-moderation-settings.json
OC_MEDIA_BURST_WINDOW_MS=30000
OC_MEDIA_BURST_LIMIT=7

# OpenChat member activity and moderation cases for rule-based automation.
OC_MEMBER_ACTIVITY_FILE=./storage/oc-member-activity.json
OC_MEMBER_ACTIVITY_GITHUB_PATH=moderation/oc-member-activity.json
OC_MODERATION_CASES_FILE=./storage/oc-moderation-cases.json
OC_MODERATION_CASES_GITHUB_PATH=moderation/oc-moderation-cases.json

# OpenChat identity test snapshots. Contains member profile-derived values for admin-only verification.
OC_IDENTITY_SNAPSHOTS_FILE=./storage/oc-identity-snapshots.json
OC_IDENTITY_SNAPSHOTS_GITHUB_PATH=moderation/oc-identity-snapshots.json

# Member name history for !log name. GitHub persistence uses the repository and token above.
MEMBER_NAME_HISTORY_FILE=./storage/member-name-history.json
MEMBER_NAME_HISTORY_GITHUB_PATH=logs/member-name-history.json
MEMBER_NAME_SCAN_INTERVAL_MS=1800000

# Message log for !log. GitHub persistence uses the repository and token above.
MESSAGE_LOG_FILE=./storage/message-log.json
MESSAGE_LOG_DIR=./storage/message-log
MESSAGE_LOG_GITHUB_PATH=logs/message-log.json
MESSAGE_LOG_BACKFILL_DELAY_MS=1500
MESSAGE_LOG_BACKFILL_LOCAL_FLUSH_PAGES=2
MESSAGE_LOG_BACKFILL_REMOTE_FLUSH_PAGES=2
MESSAGE_LOG_REMOTE_FLUSH_MAX_FILES=8
MESSAGE_LOG_PART_MAX_BYTES=5242880
MESSAGE_LOG_AUTO_FLUSH_MS=120000
MESSAGE_LOG_AUTO_HISTORY_ENABLED=true
MESSAGE_LOG_AUTO_HISTORY_INTERVAL_MS=600000
MESSAGE_LOG_AUTO_HISTORY_IDLE_MS=600000
MESSAGE_LOG_AUTO_HISTORY_QUIET_START_HOUR=2
MESSAGE_LOG_AUTO_HISTORY_QUIET_END_HOUR=6
MESSAGE_LOG_AUTO_HISTORY_RECENT_PAGES=2
MESSAGE_LOG_AUTO_HISTORY_BACKFILL_PAGES=3

# GitHub Contents API timeout for runtime data sync.
GITHUB_CONTENTS_TIMEOUT_MS=60000
GITHUB_CONTENTS_WRITE_INTERVAL_MS=1000
